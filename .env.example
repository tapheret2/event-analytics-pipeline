# =============================================================================
# Event Analytics Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline123
POSTGRES_DB=event_analytics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Airflow ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://pipeline:pipeline123@postgres:5432/event_analytics
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# --- dbt ---
DBT_PROFILES_DIR=/opt/airflow/dbt
DBT_PROJECT_DIR=/opt/airflow/dbt

# --- Pipeline Config ---
PIPELINE_DATA_DIR=/opt/airflow/data
PIPELINE_NUM_USERS=1000
PIPELINE_NUM_DAYS=30

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
